{
  "productName": "Alook",
  "version": "0.1.0",
  "identifier": "ai.alook.app",
  "build": {
    "devUrl": "http://localhost:3000/workspaces?auto",
    "frontendDist": "https://app.alook.ai/workspaces?auto"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Your Personal Company",
    "longDescription": "Run your personal company with AI agents that collaborate, stay always on, and learn from every task."
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Alook",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "capabilities": []
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["alook"]
      },
      "mobile": [
        {
          "scheme": ["alook"],
          "host": "app.alook.ai"
        }
      ]
    }
  }
}
