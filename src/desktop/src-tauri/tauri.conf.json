{
  "productName": "Alook",
  "version": "0.1.0",
  "identifier": "ai.alook.app",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://app.alook.ai"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Alook",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "capabilities": []
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["alook"]
      },
      "mobile": [
        {
          "scheme": ["alook"],
          "host": "app.alook.ai"
        }
      ]
    },
    "updater": {
      "endpoints": ["https://releases.alook.ai/desktop/{{target}}/{{arch}}/{{current_version}}"],
      "pubkey": ""
    }
  }
}
